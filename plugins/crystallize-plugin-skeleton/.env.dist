# Copy to .env and fill in. Loaded by Node (`--env-file=.env`) in prod
# and parsed by vite/dev-payload.ts in dev. DO NOT commit .env.

ENVIRONMENT=development
PLUGIN_IDENTIFIER={{plugin_identifier}}
PLUGIN_URL={{vendor_url}}
PORT=5173

# Plugin private RSA JWK on a single line (contents of private.jwk.json).
# Generate with: crystallize plugin keygen
PLUGIN_PRIVATE_JWK={{private_jwk}}

# Optional dev-payload populate-mode overrides (see vite/dev-payload.ts).
# Crystallize access token used in dev only — inlined into the locally-minted
# backendToken as `dev-payload://accessTokenId:…,accessTokenSecret:…`.
# CRYSTALLIZE_ACCESS_TOKEN_ID=
# CRYSTALLIZE_ACCESS_TOKEN_SECRET=

# Tenant identity populated into the locally-minted envelope:
# CRYSTALLIZE_TENANT_ID         → envelope.tenantId
# CRYSTALLIZE_TENANT_IDENTIFIER → overrides the path-derived :tenant segment
# CRYSTALLIZE_SIGNING_SECRET    → envelope.signatureSecret (webhook HMAC)
# CRYSTALLIZE_STATIC_AUTH_TOKEN → envelope.staticAuthToken (Discovery bearer)
# CRYSTALLIZE_TENANT_ID=
# CRYSTALLIZE_TENANT_IDENTIFIER=
# CRYSTALLIZE_SIGNING_SECRET=
# CRYSTALLIZE_STATIC_AUTH_TOKEN=
